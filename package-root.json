{
  "name": "halaqe-fullstack",
  "version": "1.0.0",
  "description": "Halaqe - Barber Booking System",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ..",
    "dev": "concurrently \"cd backend && npm run dev\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && npm run dev",
    "setup-db": "cd backend && npm run init-db",
    "seed-db": "cd backend && npm run seed",
    "reset-db": "cd backend && npm run reset-db",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
